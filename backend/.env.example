# Copy to .env and fill in. Never commit the real .env.
DATABASE_URL=postgresql://user:password@localhost:5432/moodclassifier
# Leave DATABASE_URL unset to use local SQLite for dev.
MODEL_DIR=../models
# Secret used to sign app JWTs — generate a long random string for production.
SECRET_KEY=change-me-to-a-long-random-string
# Google OAuth client ID (public; from Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
